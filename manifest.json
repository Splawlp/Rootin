{
  "manifest_version": 3,
  "name": "Rootin",
  "version": "0.1.0",
  "description": "Root your routine.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}